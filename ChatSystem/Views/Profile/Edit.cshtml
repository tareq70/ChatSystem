@model ChatSystem.Application.DTOs.User_Profile.UpdateUserProfileDTO
@{
    ViewData["Title"] = "Edit Profile";
    Layout = "_AppLayout";
}

@section Styles {
<style>
    @@import url('https://fonts.googleapis.com/css2?family=Outfit:wght@@400;500;600;700;800&display=swap');

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Outfit', sans-serif;
            min-height: 100vh;
            background: #f0f4f8;
            padding: 2rem 1rem; 
        }

        .ed-card {
            background: #fff;
            border-radius: 20px;
            width: 100%;
            max-width: 520px;
            overflow: hidden;
            box-shadow: 0 4px 24px rgba(15,23,42,0.08);
            margin: 0 auto; 
        }

    .ed-banner {
        height: 80px;
        background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 55%, #1d4ed8 100%);
        position: relative;
    }

    .ed-avatar-wrap {
        position: absolute;
        bottom: -36px;
        left: 28px;
    }

    .ed-avatar {
        width: 72px;
        height: 72px;
        border-radius: 50%;
        background: linear-gradient(135deg, #1d4ed8, #60a5fa);
        border: 4px solid #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        font-weight: 700;
        color: #fff;
        overflow: hidden;
        cursor: pointer;
        position: relative;
    }

    .ed-avatar img { width: 100%; height: 100%; object-fit: cover; }

    .ed-avatar-overlay {
        position: absolute;
        inset: 0;
        background: rgba(0,0,0,0.4);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transition: opacity 0.2s;
    }

    .ed-avatar:hover .ed-avatar-overlay { opacity: 1; }

    .ed-avatar-overlay svg {
        width: 20px;
        height: 20px;
        stroke: #fff;
        fill: none;
        stroke-width: 2;
        stroke-linecap: round;
        stroke-linejoin: round;
    }

    .ed-body { padding: 48px 28px 28px; }

    .ed-title { font-size: 18px; font-weight: 700; color: #0f172a; margin-bottom: 4px; }
    .ed-sub { font-size: 13px; color: #94a3b8; margin-bottom: 24px; }

    /* ── Errors ── */
    .ed-errors {
        background: #fef2f2;
        border: 1.5px solid #fecaca;
        border-radius: 10px;
        padding: 10px 14px;
        margin-bottom: 1.2rem;
    }

    .ed-errors ul { list-style: none; margin: 0; padding: 0; }
    .ed-errors li { font-size: 13px; color: #dc2626; padding: 2px 0; }

    /* ── Success ── */
    .ed-success {
        background: #f0fdf4;
        border: 1.5px solid #bbf7d0;
        border-radius: 10px;
        padding: 12px 14px;
        margin-bottom: 1.2rem;
        font-size: 13px;
        color: #15803d;
    }

    /* ── Fields ── */
    .ed-field { margin-bottom: 1rem; }

    .ed-label {
        font-size: 11px;
        font-weight: 700;
        color: #475569;
        display: block;
        margin-bottom: 6px;
        letter-spacing: 0.06em;
        text-transform: uppercase;
    }

    .ed-input {
        width: 100%;
        background: #f8fafc;
        border: 2px solid #e2e8f0;
        color: #0f172a;
        font-size: 14px;
        padding: 11px 14px;
        border-radius: 10px;
        outline: none;
        transition: border-color 0.2s, box-shadow 0.2s;
        font-family: 'Outfit', sans-serif;
    }

    .ed-input:focus {
        border-color: #1d4ed8;
        box-shadow: 0 0 0 3px rgba(29,78,216,0.1);
        background: #fff;
    }

    .ed-input.input-validation-error { border-color: #ef4444; }
    .ed-input::placeholder { color: #cbd5e1; }
    .field-validation-error { font-size: 11px; color: #ef4444; display: block; margin-top: 4px; }

    /* ── File upload ── */
    .ed-file-label {
        display: flex;
        align-items: center;
        gap: 10px;
        background: #f8fafc;
        border: 2px dashed #e2e8f0;
        border-radius: 10px;
        padding: 12px 14px;
        cursor: pointer;
        transition: border-color 0.2s;
    }

    .ed-file-label:hover { border-color: #1d4ed8; }

    .ed-file-icon {
        width: 36px;
        height: 36px;
        background: #eff6ff;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .ed-file-icon svg {
        width: 18px;
        height: 18px;
        stroke: #1d4ed8;
        fill: none;
        stroke-width: 2;
        stroke-linecap: round;
        stroke-linejoin: round;
    }

    .ed-file-text { font-size: 13px; color: #64748b; line-height: 1.5; }
    .ed-file-text span { color: #1d4ed8; font-weight: 600; }
    .ed-file-text small { font-size: 11px; color: #94a3b8; }
    .ed-file-name { font-size: 12px; color: #1d4ed8; margin-top: 6px; }

    /* ── Actions ── */
    .ed-actions { display: flex; gap: 10px; margin-top: 20px; }

    .ed-btn {
        flex: 1;
        background: linear-gradient(90deg, #1e3a5f, #1d4ed8);
        color: #fff;
        font-size: 14px;
        font-weight: 700;
        padding: 12px;
        border: none;
        border-radius: 10px;
        cursor: pointer;
        font-family: 'Outfit', sans-serif;
        transition: opacity 0.2s;
    }

    .ed-btn:hover { opacity: 0.88; }

    .ed-btn-cancel {
        flex: 1;
        background: #f8fafc;
        color: #64748b;
        font-size: 14px;
        font-weight: 600;
        padding: 12px;
        border: 2px solid #e2e8f0;
        border-radius: 10px;
        cursor: pointer;
        font-family: 'Outfit', sans-serif;
        text-align: center;
        text-decoration: none;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background 0.2s;
    }

    .ed-btn-cancel:hover { background: #f1f5f9; color: #64748b; }
</style>
}

<div class="ed-card">

    <!-- Banner -->
    <div class="ed-banner">
        <div class="ed-avatar-wrap">
            <div class="ed-avatar" onclick="document.getElementById('profileImageInput').click()">
                @if (!string.IsNullOrEmpty(ViewBag.CurrentImage))
                {
                    <img src="@ViewBag.CurrentImage" alt="avatar" id="avatarPreview" />
                }
                else
                {
                    <span id="avatarInitial">@ViewBag.Initial</span>
                    <img id="avatarPreview" style="display:none;" />
                }

                <div class="ed-avatar-overlay">
                    <svg viewBox="0 0 24 24">
                        <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/>
                        <circle cx="12" cy="13" r="4"/>
                    </svg>
                </div>
            </div>
        </div>
    </div>

    <!-- Body -->
    <div class="ed-body">
        <p class="ed-title">Edit profile</p>
        <p class="ed-sub">Update your username and profile picture.</p>

        @if (TempData["Success"] != null)
        {
            <div class="ed-success">@TempData["Success"]</div>
        }

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="ed-errors">
                <ul>
                    @foreach (var error in ViewData.ModelState.Values
                        .SelectMany(v => v.Errors)
                        .Where(e => !string.IsNullOrEmpty(e.ErrorMessage)))
                    {
                        <li>@error.ErrorMessage</li>
                    }
                </ul>
            </div>
        }

        <form asp-action="Edit" asp-controller="Profile" method="post" enctype="multipart/form-data" novalidate>
            @Html.AntiForgeryToken()

            <div class="ed-field">
                <label asp-for="UserName" class="ed-label"></label>
                <input asp-for="UserName" class="ed-input" placeholder="john_doe" autocomplete="username" />
                <span asp-validation-for="UserName" class="field-validation-error"></span>
            </div>

            <div class="ed-field">
                <label class="ed-label">Profile picture</label>
                <label class="ed-file-label" for="profileImageInput">
                    <div class="ed-file-icon">
                        <svg viewBox="0 0 24 24">
                            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                            <polyline points="17 8 12 3 7 8"/>
                            <line x1="12" y1="3" x2="12" y2="15"/>
                        </svg>
                    </div>
                    <div class="ed-file-text">
                        <span>Click to upload</span> or drag and drop<br/>
                        <small>PNG, JPG up to 2MB</small>
                    </div>
                </label>
                <input asp-for="ProfileImage"
                       type="file"
                       id="profileImageInput"
                       accept="image/*"
                       style="display:none"
                       onchange="previewImage(this)" />
                <p class="ed-file-name" id="fileName"></p>
            </div>

            <div class="ed-actions">
                <a asp-action="Index" asp-controller="Profile" class="ed-btn-cancel">Cancel</a>
                <button type="submit" class="ed-btn">Save changes</button>
            </div>
        </form>

    </div>
</div>

@section Scripts {
<script>
    function previewImage(input) {
        const file = input.files[0];
        if (!file) return;

        document.getElementById('fileName').textContent = file.name;

        const reader = new FileReader();
        reader.onload = e => {
            const preview  = document.getElementById('avatarPreview');
            const initial  = document.getElementById('avatarInitial');
            preview.src    = e.target.result;
            preview.style.display = 'block';
            if (initial) initial.style.display = 'none';
        };
        reader.readAsDataURL(file);
    }
</script>
}