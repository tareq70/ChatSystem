<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Chatk</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        @@import url('https://fonts.googleapis.com/css2?family=Outfit:wght@@400;500;600;700&display=swap');

        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Outfit', sans-serif;
            min-height: 100vh;
            background: #f0f4f8;
        }

        /* ── Navbar ── */
        .app-navbar {
            background: #fff;
            border-bottom: 1px solid #e2e8f0;
            padding: 0 2rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            height: 60px;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .nav-logo {
            display: flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
        }

        .nav-logo-mark {
            width: 32px;
            height: 32px;
            background: #1d4ed8;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

            .nav-logo-mark svg {
                width: 16px;
                height: 16px;
                fill: #fff;
            }

        .nav-logo-name {
            font-size: 16px;
            font-weight: 700;
            color: #0f172a;
        }

        .nav-links {
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .nav-link {
            display: flex;
            align-items: center;
            gap: 6px;
            padding: 7px 14px;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 500;
            color: #64748b;
            text-decoration: none;
            transition: background 0.15s, color 0.15s;
            cursor: pointer;
            border: none;
            background: none;
            font-family: 'Outfit', sans-serif;
        }

            .nav-link:hover {
                background: #f1f5f9;
                color: #0f172a;
            }

            .nav-link.active {
                background: #eff6ff;
                color: #1d4ed8;
            }

            .nav-link svg {
                width: 17px;
                height: 17px;
                stroke: currentColor;
                fill: none;
                stroke-width: 2;
                stroke-linecap: round;
                stroke-linejoin: round;
            }

        .nav-logout {
            color: #ef4444;
        }

            .nav-logout:hover {
                background: #fef2f2;
                color: #dc2626;
            }

        .nav-divider {
            width: 1px;
            height: 24px;
            background: #e2e8f0;
            margin: 0 4px;
        }

        /* ── Page content ── */
        .app-content {
            min-height: calc(100vh - 60px);
        }

        @@media (max-width: 640px) {
            .app-navbar {
                padding: 0 1rem;
            }

            .nav-link span {
                display: none;
            }

            .nav-link {
                padding: 7px 10px;
            }
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <nav class="app-navbar">
        <a class="nav-logo" asp-controller="Profile" asp-action="Index">
            <div class="nav-logo-mark">
                <svg viewBox="0 0 18 18"><path d="M9 0L18 9L9 18L0 9Z" /></svg>
            </div>
            <span class="nav-logo-name">Chatk</span>
        </a>

        <div class="nav-links">
            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Chat" ? "active" : "")"
               asp-controller="Chat" asp-action="Index">
                <svg viewBox="0 0 24 24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" /></svg>
                <span>Chat</span>
            </a>

            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Friends" ? "active" : "")"
               asp-controller="Friends" asp-action="Index">
                <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M23 21v-2a4 4 0 0 0-3-3.87" /><path d="M16 3.13a4 4 0 0 1 0 7.75" /></svg>
                <span>Friends</span>
            </a>

            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Profile" ? "active" : "")"
               asp-controller="Profile" asp-action="Index">
                <svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" /><circle cx="12" cy="7" r="4" /></svg>
                <span>Profile</span>
            </a>

            <div class="nav-divider"></div>

            <form asp-controller="Auth" asp-action="Logout" method="post" style="margin:0">
                @Html.AntiForgeryToken()
                <button type="submit" class="nav-link nav-logout">
                    <svg viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" /><polyline points="16 17 21 12 16 7" /><line x1="21" y1="12" x2="9" y2="12" /></svg>
                    <span>Logout</span>
                </button>
            </form>
        </div>
    </nav>

    <div class="app-content">
        @RenderBody()
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
