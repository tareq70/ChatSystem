@using ChatSystem.Application.DTOs.Search
@using ChatSystem.Core.Enums
@using ChatSystem.Application.DTOs
@model List<UserSearchResultDto>

@{
    ViewData["Title"] = "Search Users";
    Layout = "_AppLayout";
    var query = Context.Request.Query["q"].ToString();
}
@functions {
    string GetLastSeen(DateTime lastSeen)
    {
        var diff = DateTime.UtcNow - lastSeen;
        if (diff.TotalMinutes < 1) return "just now";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours}h ago";
        return $"{(int)diff.TotalDays}d ago";
    }
}

@section Styles {
    <style>
        .search-page {
            max-width: 680px;
            margin: 48px auto;
            padding: 0 1rem;
        }

        .search-heading {
            font-size: 13px;
            font-weight: 600;
            color: #94a3b8;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            margin-bottom: 16px;
        }

        .user-card {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 14px 16px;
            background: #fff;
            border: 1px solid #e2e8f0;
            border-radius: 12px;
            margin-bottom: 10px;
            transition: box-shadow 0.15s, border-color 0.15s;
        }

            .user-card:hover {
                border-color: #bfdbfe;
                box-shadow: 0 2px 12px rgba(29,78,216,0.07);
            }

        .user-avatar {
            width: 48px;
            height: 48px;
            border-radius: 50%;
            object-fit: cover;
            flex-shrink: 0;
            border: 2px solid #e2e8f0;
        }

        .user-info {
            flex: 1;
            min-width: 0;
        }

        .user-name {
            font-size: 15px;
            font-weight: 600;
            color: #0f172a;
            margin-bottom: 2px;
        }

        .user-email {
            font-size: 13px;
            color: #94a3b8;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .user-status {
            display: flex;
            align-items: center;
            gap: 5px;
            font-size: 12px;
            font-weight: 500;
            margin-top: 4px;
        }

        .status-dot {
            width: 7px;
            height: 7px;
            border-radius: 50%;
        }

            .status-dot.online {
                background: #22c55e;
            }

            .status-dot.offline {
                background: #cbd5e1;
            }

        .user-status.online {
            color: #16a34a;
        }

        .user-status.offline {
            color: #94a3b8;
        }

        /* Buttons */
        .btn-profile {
            padding: 7px 16px;
            border-radius: 8px;
            font-size: 13px;
            font-weight: 500;
            color: #1d4ed8;
            border: 1px solid #bfdbfe;
            background: #eff6ff;
            text-decoration: none;
            white-space: nowrap;
            transition: background 0.15s;
            flex-shrink: 0;
        }

            .btn-profile:hover {
                background: #dbeafe;
                color: #1d4ed8;
            }

        .btn-add {
            padding: 7px 16px;
            border-radius: 8px;
            font-size: 13px;
            font-weight: 500;
            color: #fff;
            border: none;
            background: #1d4ed8;
            white-space: nowrap;
            transition: background 0.15s;
            cursor: pointer;
            flex-shrink: 0;
        }

            .btn-add:hover {
                background: #1e40af;
            }

        .btn-pending {
            padding: 7px 16px;
            border-radius: 8px;
            font-size: 13px;
            font-weight: 500;
            color: #92400e;
            border: 1px solid #fde68a;
            background: #fefce8;
            white-space: nowrap;
            flex-shrink: 0;
            cursor: default;
        }

        .btn-friends {
            padding: 7px 16px;
            border-radius: 8px;
            font-size: 13px;
            font-weight: 500;
            color: #166534;
            border: 1px solid #bbf7d0;
            background: #f0fdf4;
            white-space: nowrap;
            flex-shrink: 0;
            cursor: default;
        }

        .card-actions {
            display: flex;
            align-items: center;
            gap: 8px;
            flex-shrink: 0;
        }

        .no-results {
            text-align: center;
            padding: 48px 0;
            color: #94a3b8;
            font-size: 15px;
        }
    </style>
}

<div class="search-page">

    @if (Model.Any())
    {
        <p class="search-heading">
            @Model.Count result@(Model.Count > 1 ? "s" : "") for "@query"
        </p>

        @foreach (var item in Model)
        {
            var isOnline = item.Status == UserStatus.Online;

            <div class="user-card">

                <img src="@(string.IsNullOrEmpty(item.ProfileImage)
                         ? "https://ui-avatars.com/api/?name=" + item.UserName + "&background=1d4ed8&color=fff&size=48"
                         : item.ProfileImage)"
                     class="user-avatar" alt="@item.UserName" />

                <div class="user-info">
                    <div class="user-name">@item.UserName</div>
                    <div class="user-email">@item.Email</div>

                    <div class="user-status @(isOnline ? "online" : "offline")">
                        <div class="status-dot @(isOnline ? "online" : "offline")"></div>
                        @if (isOnline)
                        {
                            <span>Online</span>
                        }
                        else if (item.LastSeen.HasValue)
                        {
                            <span>Last seen @GetLastSeen(item.LastSeen.Value)</span>
                        }
                        else
                        {
                            <span>Offline</span>
                        }
                    </div>


                </div>

                <div class="card-actions">

                    <a asp-controller="Search"
                       asp-action="ShowProfile"
                       asp-route-id="@item.Id"
                       class="btn-profile">
                        View Profile
                    </a>

                    @if (item.RequestStatus == null || item.RequestStatus == FriendRequestStatus.Rejected)
                    {
                        <form method="post" asp-controller="FriendRequest" asp-action="Send">
                            <input type="hidden" name="receiverId" value="@item.Id" />
                            <input type="hidden" name="q" value="@query" />
                            <button type="submit" class="btn-add">Add Friend</button>
                        </form>
                    }
                    else if (item.RequestStatus == FriendRequestStatus.Pending)
                    {
                        <span class="btn-pending">⏳ Pending</span>
                    }
                    else if (item.RequestStatus == FriendRequestStatus.Accepted)
                    {
                        <span class="btn-friends">✅ Friends</span>
                    }

                </div>

            </div>
        }
    }
    else if (!string.IsNullOrWhiteSpace(query))
    {
        <div class="no-results">
            <p>No results for "<strong>@query</strong>"</p>
        </div>
    }

</div>