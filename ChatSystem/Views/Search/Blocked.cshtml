@{
    ViewData["Title"] = "Access Denied";
    Layout = "_AppLayout";
}

<div style="text-align:center; padding: 80px 20px;">
    <div style="font-size:48px; margin-bottom:16px;">🚫</div>
    <h2 style="font-size:20px; font-weight:700; color:#0f172a; margin-bottom:8px;">
        This profile is not available
    </h2>
    <p style="color:#94a3b8; font-size:14px; margin-bottom:24px;">
        You are not allowed to view this profile.
    </p>
    <a asp-controller="Search" asp-action="Index"
       style="padding:8px 20px; background:#1d4ed8; color:#fff;
              border-radius:8px; text-decoration:none; font-size:14px;">
        Back to Search
    </a>
</div>