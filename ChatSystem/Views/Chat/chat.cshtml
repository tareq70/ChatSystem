@model IEnumerable<MessageDto>
@using System.Security.Claims
@using ChatSystem.Application.DTOs.chating
@using ChatSystem.Core.Enums
@{
    Layout = "~/Views/Shared/_AppLayout.cshtml";
    ViewData["Title"] = "Chat";
    var friendId = (string?)ViewBag.FriendId;
    var chatId = (int)ViewBag.ChatId;
    var chatType = (string)ViewBag.ChatType;
    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    var groupDetails = ViewBag.GroupDetails as GroupDetailsDto;
    var isAdmin = groupDetails?.CreatedByUserId == currentUserId
                         && !string.IsNullOrEmpty(currentUserId);

    var friendName = (string?)ViewBag.FriendName ?? "Unknown";
    var friendImage = (string?)ViewBag.FriendImage;
    var friendStatus = ViewBag.FriendStatus is UserStatus s ? s : UserStatus.Offline;
}

@Html.AntiForgeryToken()

@section Styles {
    <style>
        /* ── Layout ─────────────────────────────────────────────── */
        .chat-page {
            display: flex;
            height: calc(100vh - 60px);
            overflow: hidden;
            max-width: 960px;
            margin: auto;
        }

        /* ── Sidebar ─────────────────────────────────────────────── */
        .chat-sidebar {
            width: 260px;
            border-right: 1px solid var(--bs-border-color);
            flex-shrink: 0;
            overflow-y: auto;
            padding: 16px 12px;
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        .sidebar-section-label {
            font-size: .72rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: .06em;
            color: var(--bs-secondary-color);
            padding: 0 4px;
            margin: 6px 0 2px;
        }

        .group-header {
            text-align: center;
            padding-bottom: 12px;
            border-bottom: 1px solid var(--bs-border-color);
            margin-bottom: 4px;
        }

        .group-header-avatar {
            width: 58px;
            height: 58px;
            border-radius: 14px;
            object-fit: cover;
            margin-bottom: 6px;
        }

        .group-header-icon {
            font-size: 2.2rem;
            margin-bottom: 4px;
            display: block;
        }

        /* ── Member card ─────────────────────────────────────────── */
        .member-card {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 6px 8px;
            border-radius: 8px;
            transition: background .12s;
            position: relative;
            
        }

            .member-card:hover {
                background: var(--bs-secondary-bg);
            }

            .member-card img {
                width: 34px;
                height: 34px;
                border-radius: 50%;
                object-fit: cover;
                flex-shrink: 0;
            }

            .member-card .name {
                font-size: .82rem;
                font-weight: 500;
            }

            .member-card .role {
                font-size: .71rem;
                color: var(--bs-secondary-color);
            }

        .btn-remove-member {
            background: none;
            border: none;
            padding: 3px 6px;
            border-radius: 6px;
            cursor: pointer;
            color: var(--bs-secondary-color);
            opacity: 0; 
            transition: opacity .15s, color .15s;
            flex-shrink: 0;
            line-height: 1;
        }

        .member-card:hover .btn-remove-member {
            opacity: 1;
        }
        .btn-remove-member:hover {
            color: var(--bs-danger);
        }

       

        /* ── Sidebar actions ─────────────────────────────────────── */
        .sidebar-actions {
            margin-top: auto;
            padding-top: 10px;
            border-top: 1px solid var(--bs-border-color);
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        /* ── Chat main ───────────────────────────────────────────── */
        .chat-main {
            flex: 1;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        .chat-header {
            padding: 12px 16px;
            border-bottom: 1px solid var(--bs-border-color);
            display: flex;
            align-items: center;
            gap: 10px;
        }

        /* ── Messages ────────────────────────────────────────────── */
        .messages-area {
            flex: 1;
            overflow-y: auto;
            padding: 16px;
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .msg-row {
            display: flex;
            flex-direction: column;
        }

            .msg-row.own {
                align-items: flex-end;
            }

            .msg-row.other {
                align-items: flex-start;
            }

        .sender-name {
            font-size: .73rem;
            color: var(--bs-secondary-color);
            margin-bottom: 2px;
            padding: 0 4px;
        }

        .bubble {
            max-width: 62%;
            padding: 9px 14px;
            border-radius: 18px;
            font-size: .88rem;
            line-height: 1.45;
            word-break: break-word;
            position: relative;
        }

            .bubble.own {
                background: #3b82f6;
                color: #fff;
                border-bottom-right-radius: 5px;
            }

            .bubble.other {
                background: var(--bs-secondary-bg);
                border-bottom-left-radius: 5px;
            }

        .msg-meta {
            font-size: .7rem;
            opacity: .6;
            margin-top: 3px;
            display: flex;
            align-items: center;
            gap: 4px;
            padding: 0 2px;
        }

        .read-tick {
            font-size: .75rem;
        }

            .read-tick.read {
                color: #3b82f6;
                opacity: 1;
            }

        /* ── File / Image bubbles ────────────────────────────────── */
        .file-bubble {
            display: flex;
            align-items: center;
            gap: 8px;
        }

            .file-bubble i {
                font-size: 1.2rem;
            }

        .img-bubble img {
            max-width: 200px;
            border-radius: 12px;
            display: block;
            cursor: pointer;
        }

        /* ── Input bar ───────────────────────────────────────────── */
        .chat-input-bar {
            border-top: 1px solid var(--bs-border-color);
            padding: 10px 14px;
            display: flex;
            gap: 8px;
            align-items: flex-end;
            position: relative;
        }

        .input-wrap {
            flex: 1;
            background: var(--bs-secondary-bg);
            border-radius: 22px;
            padding: 8px 14px;
            display: flex;
            align-items: flex-end;
            gap: 6px;
        }

            .input-wrap textarea {
                flex: 1;
                background: transparent;
                border: none;
                outline: none;
                resize: none;
                font-size: .88rem;
                line-height: 1.4;
                max-height: 120px;
                color: var(--bs-body-color);
            }

        .emoji-btn, .file-btn {
            background: none;
            border: none;
            font-size: 1.2rem;
            cursor: pointer;
            padding: 0;
            line-height: 1;
            color: var(--bs-secondary-color);
        }

            .emoji-btn:hover, .file-btn:hover {
                color: var(--bs-body-color);
            }

        .send-btn {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            border: none;
            background: #3b82f6;
            color: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            flex-shrink: 0;
            transition: opacity .15s;
        }

            .send-btn:disabled {
                opacity: .5;
                cursor: not-allowed;
            }

        .typing-bar {
            font-size: .78rem;
            color: var(--bs-secondary-color);
            min-height: 18px;
            padding: 2px 16px;
        }

        /* ── Emoji picker ────────────────────────────────────────── */
        .emoji-picker {
            position: absolute;
            bottom: 70px;
            left: 14px;
            background: var(--bs-body-bg);
            border: 1px solid var(--bs-border-color);
            border-radius: 12px;
            padding: 10px;
            display: grid;
            grid-template-columns: repeat(8, 1fr);
            gap: 4px;
            z-index: 200;
            box-shadow: 0 4px 20px rgba(0,0,0,.15);
        }

            .emoji-picker button {
                background: none;
                border: none;
                font-size: 1.25rem;
                cursor: pointer;
                padding: 4px;
                border-radius: 6px;
                transition: background .1s;
            }

                .emoji-picker button:hover {
                    background: var(--bs-secondary-bg);
                }

        /* ── Lightbox ────────────────────────────────────────────── */
        .lightbox {
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,.88);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 9999;
            cursor: zoom-out;
        }

            .lightbox.active {
                display: flex;
            }

            .lightbox img {
                max-width: 90vw;
                max-height: 90vh;
                border-radius: 8px;
            }

        /* ── Modal tweaks ────────────────────────────────────────── */
        .add-friend-row {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 8px 10px;
            border-radius: 10px;
            border: 1px solid var(--bs-border-color);
            transition: background .12s;
        }

            .add-friend-row:hover {
                background: var(--bs-secondary-bg);
            }

            .add-friend-row img {
                width: 36px;
                height: 36px;
                border-radius: 50%;
                object-fit: cover;
            }
    </style>
}

<div class="chat-page position-relative">

    <!-- ════════════════ SIDEBAR ════════════════ -->
    <div class="chat-sidebar">
        @if (chatType == "Group" && groupDetails is not null)
        {
            
            <!-- Group header -->
            <div class="group-header">
                @if (groupDetails.GroupImage != null)
                {
                    <img src="@groupDetails.GroupImage" class="group-header-avatar" alt="@groupDetails.Name" />
                }
                else
                {
                    <span class="group-header-icon">👥</span>
                }
                <div class="fw-semibold" style="font-size:.92rem">@groupDetails.Name</div>
                <div class="text-muted" style="font-size:.75rem">@groupDetails.Members.Count members</div>
            </div>

            <!-- Members -->
            <div class="sidebar-section-label">Members</div>
            <div id="membersList">
                @foreach (var m in groupDetails.Members)
                {
                    <div class="member-card" id="member-@m.UserId">
                        <img src="@(m.ProfileImage ?? $"https://ui-avatars.com/api/?name={Uri.EscapeDataString(m.UserName)}&background=random")"
                             alt="@m.UserName" />
                        <div class="flex-grow-1 overflow-hidden">
                            <div class="name text-truncate">@m.UserName</div>
                            <div class="role">@(m.IsAdmin ? "Admin" : "Member")</div>
                        </div>
                        @if (isAdmin && !m.IsAdmin)
                        {
                            <button class="btn-remove-member"
                                    title="Remove member"
                                    onclick="confirmRemoveMember('@m.UserId', '@Html.Raw(m.UserName.Replace("'", "\\'"))')">
                                <i class="bi bi-x-lg" style="font-size:.8rem"></i>
                            </button>
                        }
                    </div>
                }
            </div>

            <!-- Actions -->
            <div class="sidebar-actions">
                @if (isAdmin)
                {
                    <button class="btn btn-sm btn-outline-primary w-100"
                            onclick="openAddMemberModal()">
                        <i class="bi bi-person-plus me-1"></i>Add Member
                    </button>
                    <button class="btn btn-sm btn-outline-secondary w-100"
                            data-bs-toggle="modal" data-bs-target="#editGroupModal">
                        <i class="bi bi-pencil me-1"></i>Edit Group
                    </button>
                }
                <button class="btn btn-sm btn-outline-danger w-100"
                        onclick="leaveGroup()">
                    <i class="bi bi-box-arrow-left me-1"></i>Leave Group
                </button>
               
            </div>
        }
        else
        {
            <div class="text-center py-3">
                <div class="position-relative d-inline-block mb-2">
                    <img src="@(friendImage ?? $"https://ui-avatars.com/api/?name={Uri.EscapeDataString(friendName)}&background=random")"
                         style="width:64px;height:64px;border-radius:50%;object-fit:cover"
                         alt="@friendName" />
                    @if (friendStatus == UserStatus.Online)
                    {
                        <span style="width:13px;height:13px;border-radius:50%;background:#22c55e;
                                     border:2px solid var(--bs-body-bg);position:absolute;
                                     bottom:2px;right:2px;display:block"></span>
                    }
                </div>
                <div class="fw-semibold" style="font-size:.9rem">@friendName</div>
                <div class="text-muted" style="font-size:.75rem">
                    @(friendStatus == UserStatus.Online ? "🟢 Online" : "⚫ Offline")
                </div>
                <a href="@Url.Action("ShowProfile", "Search", new { id = friendId })"
                   class="btn btn-sm btn-outline-secondary mt-2 w-100"
                   style="font-size:.8rem">
                    <i class="bi bi-person me-1"></i>View Profile
                </a>
            </div>
        }
    </div>

    <!-- ════════════════ MAIN CHAT ════════════════ -->
    <div class="chat-main">

        <!-- Header -->
        <div class="chat-header">
            @if (chatType == "Group" && groupDetails is not null)
            {
                @if (groupDetails.GroupImage != null)
                {
                    <img src="@groupDetails.GroupImage"
                         style="width:38px;height:38px;border-radius:10px;object-fit:cover" alt="" />
                }
                else
                {
                    <span style="font-size:1.4rem">👥</span>
                }
                <div>
                    <div class="fw-semibold" style="font-size:.95rem">@groupDetails.Name</div>
                    <div style="font-size:.75rem;color:var(--bs-secondary-color)">
                        @groupDetails.Members.Count members
                    </div>
                </div>
            }
            else
            {
                <!-- ← Private chat header جديد -->
                <div class="position-relative" style="flex-shrink:0">
                    <img src="@(friendImage ?? $"https://ui-avatars.com/api/?name={Uri.EscapeDataString(friendName)}&background=random")"
                         style="width:40px;height:40px;border-radius:50%;object-fit:cover"
                         alt="@friendName" />
                    @if (friendStatus == UserStatus.Online)
                    {
                        <span style="width:11px;height:11px;border-radius:50%;background:#22c55e;
                                     border:2px solid var(--bs-body-bg);position:absolute;
                                     bottom:1px;right:1px;display:block"></span>
                    }
                </div>
                <div>
                    <div class="fw-semibold" style="font-size:.95rem">@friendName</div>
                    <div style="font-size:.75rem;color:var(--bs-secondary-color)">
                        @(friendStatus == UserStatus.Online ? "Online" : "Offline")
                    </div>
                </div>
                <a href="@Url.Action("ShowProfile", "Search", new { id = friendId })"
                   class="btn btn-sm btn-outline-secondary ms-auto"
                   style="font-size:.78rem">
                    <i class="bi bi-person me-1"></i>View Profile
                </a>
            }
        </div>

        <!-- Messages -->
        <div class="messages-area" id="messagesArea">
            @foreach (var msg in Model)
            {
                <div class="msg-row @(msg.IsOwn ? "own" : "other")" data-msg-id="@msg.Id">
                    @if (chatType == "Group" && !msg.IsOwn)
                    {
                        <div class="sender-name">@msg.SenderName</div>
                    }
                    <div class="bubble @(msg.IsOwn ? "own" : "other")">
                        @if (msg.Type == MessageType.Image)
                        {
                            <div class="img-bubble">
                                <img src="@msg.FileUrl" alt="@msg.FileName"
                                     onclick="openLightbox(this.src)" />
                            </div>
                        }
                        else if (msg.Type == MessageType.File)
                        {
                            <div class="file-bubble">
                                <i class="bi bi-file-earmark-fill"></i>
                                <a href="@msg.FileUrl" download="@msg.FileName"
                                   class="@(msg.IsOwn ? "text-white" : "")">@msg.FileName</a>
                            </div>
                        }
                        else
                        {
                            @msg.Content
                        }
                    </div>
                    <div class="msg-meta">
                        <span>@msg.SentAt.ToString("hh:mm tt")</span>
                        @if (msg.IsOwn)
                        {
                            <span class="read-tick @(msg.IsRead ? "read" : "")">
                                @(msg.IsRead ? "✓✓" : "✓")
                            </span>
                        }
                    </div>
                </div>
            }
        </div>

        <!-- Typing indicator -->
        <div class="typing-bar" id="typingBar"></div>

        <!-- Input bar -->
        <div class="chat-input-bar">
            <!-- Emoji picker -->
            <div class="emoji-picker" id="emojiPicker" style="display:none">
                @foreach (var emoji in new[] {
                                        "😀","😂","😍","🥰","😎","🤔","😢","😡",
                                        "👍","👎","❤️","🔥","✨","🎉","💯","🙏",
                                        "😭","🤣","😊","😘","🫂","💪","🤝","👀",
                                        "💀","🥹","😤","🤯","🫡","🙌"
                                })
                {
                    <button type="button" onclick="insertEmoji('@emoji')">@emoji</button>
                }
            </div>

            <div class="input-wrap">
                <button class="emoji-btn" type="button"
                        onclick="toggleEmojiPicker()" title="Emoji">
                    😊
                </button>
                <textarea id="msgInput" rows="1"
                          placeholder="Type a message..."></textarea>
                <label class="file-btn" title="Attach file">
                    <i class="bi bi-paperclip"></i>
                    <input type="file" id="fileInput" style="display:none"
                           accept="image/*,.pdf,.doc,.docx,.zip,.txt" />
                </label>
            </div>
            <button class="send-btn" id="sendBtn" disabled>
                <i class="bi bi-send-fill" style="font-size:.85rem"></i>
            </button>
        </div>
    </div>
</div>

<!-- ════════ Lightbox ════════ -->
<div class="lightbox" id="lightbox" onclick="closeLightbox()">
    <img id="lightboxImg" src="" alt="" />
</div>

<!-- ════════ Add Member Modal ════════ -->
<div class="modal fade" id="addMemberModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h6 class="modal-title fw-semibold">Add Member</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body pt-2">
                <div id="addMemberList" class="d-flex flex-column gap-2">
                    <div class="text-center text-muted py-4">
                        <div class="spinner-border spinner-border-sm"></div>
                        <div class="mt-2" style="font-size:.82rem">Loading friends…</div>
                    </div>
                </div>
                <div id="addMemberEmpty" class="text-center text-muted py-4"
                     style="display:none; font-size:.85rem">
                    <i class="bi bi-people fs-3 d-block mb-1"></i>
                    No friends available to add.
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ════════ Edit Group Modal ════════ -->
<div class="modal fade" id="editGroupModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h6 class="modal-title fw-semibold">Edit Group</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label small fw-medium">Group Name</label>
                    <input type="text" id="editGroupName" class="form-control"
                           value="@groupDetails?.Name" placeholder="Group name" />
                </div>
                <div class="mb-1">
                    <label class="form-label small fw-medium">Group Image</label>
                    @if (groupDetails?.GroupImage != null)
                    {
                        <div class="mb-2">
                            <img src="@groupDetails.GroupImage"
                                 style="width:50px;height:50px;border-radius:12px;object-fit:cover" />
                        </div>
                    }
                    <input type="file" id="editGroupImage"
                           class="form-control form-control-sm" accept="image/*" />
                </div>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-secondary btn-sm"
                        data-bs-dismiss="modal">
                    Cancel
                </button>
                <button type="button" class="btn btn-primary btn-sm"
                        id="saveGroupBtn" onclick="saveGroupEdit()">
                    Save Changes
                </button>
            </div>
        </div>
    </div>
</div>

<!-- ════════ Confirm Remove Modal ════════ -->
<div class="modal fade" id="confirmRemoveModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content">
            <div class="modal-body text-center py-4 px-3">
                <i class="bi bi-person-x fs-1 text-danger d-block mb-2"></i>
                <div class="fw-semibold mb-1">Remove Member?</div>
                <div class="text-muted mb-3" style="font-size:.85rem"
                     id="removeConfirmText"></div>
                <div class="d-flex gap-2 justify-content-center">
                    <button class="btn btn-secondary btn-sm"
                            data-bs-dismiss="modal">
                        Cancel
                    </button>
                    <button class="btn btn-danger btn-sm"
                            id="confirmRemoveBtn">
                        Remove
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ════════ Leave Group Modal ════════ -->
<div class="modal fade" id="leaveGroupModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content">
            <div class="modal-body text-center py-4 px-3">
                <i class="bi bi-box-arrow-left fs-1 text-danger d-block mb-2"></i>
                <div class="fw-semibold mb-1">Leave Group?</div>
                <div class="text-muted mb-3" style="font-size:.85rem">
                    You won't be able to see this group's messages anymore.
                </div>
                <div class="d-flex gap-2 justify-content-center">
                    <button class="btn btn-secondary btn-sm"
                            data-bs-dismiss="modal">
                        Cancel
                    </button>
                    <button class="btn btn-danger btn-sm"
                            id="confirmLeaveBtn">
                        Leave
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script>
        /* ── Constants ──────────────────────────────────────────────── */
        const chatId        = @chatId;
        const currentUserId = "@currentUserId";
        const chatType      = "@chatType";
        let typingTimer, isPickerOpen = false;
        let pendingRemoveId = null;
        const pendingMessages = new Set();

        /* ── CSRF helpers ───────────────────────────────────────────── */
        function getCsrfToken() {
            return document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? "";
        }

        async function postForm(url, data) {
            const body = new URLSearchParams({ ...data, __RequestVerificationToken: getCsrfToken() });
            const res  = await fetch(url, {
                method:  "POST",
                headers: { "Content-Type": "application/x-www-form-urlencoded" },
                body:    body.toString()
            });
            const ct = res.headers.get("Content-Type") ?? "";
            if (!ct.includes("application/json")) return { success: true };
            return res.json();
        }

        async function postMultipart(url, formData) {
            formData.append("__RequestVerificationToken", getCsrfToken());
            const res = await fetch(url, { method: "POST", body: formData });
            const ct  = res.headers.get("Content-Type") ?? "";
            if (!ct.includes("application/json")) return { success: true };
            return res.json();
        }

        /* ── SignalR ────────────────────────────────────────────────── */
        const hub = new signalR.HubConnectionBuilder()
            .withUrl("/hubs/chat")
            .withAutomaticReconnect()
            .build();

        hub.on("ReceiveMessage", msg => {
            // لو إحنا اللي بعتناها — متضيفهاش تاني، بس حدّث الـ ID
            if (msg.senderId === currentUserId && pendingMessages.has("pending")) {
                pendingMessages.delete("pending");
                const lastRow = document.querySelector(".msg-row.pending-msg");
                if (lastRow) {
                    lastRow.setAttribute("data-msg-id", msg.id);
                    lastRow.classList.remove("pending-msg");
                }
                return;
            }
            appendMessage(msg);
            scrollToBottom();
            if (msg.senderId !== currentUserId)
                hub.invoke("MarkRead", chatId).catch(() => {});
        });

        hub.on("TypingIndicator", (userId, typing) => {
            if (userId === currentUserId) return;
            document.getElementById("typingBar").textContent = typing ? "typing..." : "";
        });

        hub.on("MessagesRead", (cid, userId) => {
            if (cid !== chatId) return;
            if (userId === currentUserId) return;
            // حدّث كل علامات الصح للرسائل بتاعتنا
            document.querySelectorAll(".msg-row.own .read-tick").forEach(el => {
                el.textContent = "✓✓";
                el.classList.add("read");
            });
        });

        async function start() {
            await hub.start();
            await hub.invoke("JoinChat", chatId);
            scrollToBottom();
        }
              
        start();

        /* ── Send text ──────────────────────────────────────────────── */
        document.getElementById("sendBtn").addEventListener("click", sendText);

        document.getElementById("msgInput").addEventListener("keydown", e => {
            if (e.key === "Enter" && !e.shiftKey) { e.preventDefault(); sendText(); }
        });

        document.getElementById("msgInput").addEventListener("input", function () {
            document.getElementById("sendBtn").disabled = !this.value.trim();
            autoResize(this);
            hub.invoke("Typing", chatId, true).catch(() => {});
            clearTimeout(typingTimer);
            typingTimer = setTimeout(() => hub.invoke("Typing", chatId, false).catch(() => {}), 1500);
        });

        async function sendText() {
            const input   = document.getElementById("msgInput");
            const content = input.value.trim();
            if (!content) return;

            input.value = "";
            input.style.height = "";
            document.getElementById("sendBtn").disabled = true;
            clearTimeout(typingTimer);
            hub.invoke("Typing", chatId, false).catch(() => {});

            // أضف الرسالة محلياً فوراً
            pendingMessages.add("pending");
            appendLocalMessage(content);
            scrollToBottom();

            await hub.invoke("SendMessage", chatId, content, "Text", null, null);
        }

        /* ── File upload ────────────────────────────────────────────── */
        document.getElementById("fileInput").addEventListener("change", async function () {
            const file = this.files[0];
            if (!file) return;
            const form = new FormData();
            form.append("file",   file);
            form.append("chatId", chatId);
            try {
                const data = await postMultipart('@Url.Action("UploadFile", "Chat")', form);
                this.value = "";
                await hub.invoke("SendMessage", chatId, null, data.type, data.fileUrl, data.fileName);
            } catch {
                alert("File upload failed. Make sure it's under 10MB.");
                this.value = "";
            }
        });

        /* ── Leave Group ────────────────────────────────────────────── */
        function leaveGroup() {
            new bootstrap.Modal(document.getElementById("leaveGroupModal")).show();
        }

        document.getElementById("confirmLeaveBtn").addEventListener("click", async () => {
            const btn = document.getElementById("confirmLeaveBtn");
            btn.disabled    = true;
            btn.textContent = "Leaving…";

            try {
                const res = await postForm('@Url.Action("LeaveGroup", "Chat")', { chatId });
                if (res.success !== false) {
                    window.location.href = '@Url.Action("Index", "Chat")';
                } else {
                    alert(res.message ?? "Failed to leave group.");
                    btn.disabled    = false;
                    btn.textContent = "Leave";
                }
            } catch {
                alert("Something went wrong.");
                btn.disabled    = false;
                btn.textContent = "Leave";
            }
        });

        /* ── Remove Member ──────────────────────────────────────────── */
        function confirmRemoveMember(userId, userName) {
            pendingRemoveId = userId;
            document.getElementById("removeConfirmText").textContent =
                `Remove "${userName}" from the group?`;
            new bootstrap.Modal(document.getElementById("confirmRemoveModal")).show();
        }

        document.getElementById("confirmRemoveBtn").addEventListener("click", async () => {
            if (!pendingRemoveId) return;
            const btn = document.getElementById("confirmRemoveBtn");
            btn.disabled    = true;
            btn.textContent = "Removing…";
            try {
                const res = await postForm('@Url.Action("RemoveMember", "Chat")',
                    { chatId, userId: pendingRemoveId });
                if (res.success !== false) {
                    document.getElementById(`member-${pendingRemoveId}`)?.remove();
                    bootstrap.Modal.getInstance(
                        document.getElementById("confirmRemoveModal")).hide();
                } else {
                    alert(res.message ?? "Failed to remove member.");
                }
            } catch {
                alert("Something went wrong.");
            } finally {
                btn.disabled    = false;
                btn.textContent = "Remove";
                pendingRemoveId = null;
            }
        });

        /* ── Add Member ─────────────────────────────────────────────── */
        async function openAddMemberModal() {
            const modal = new bootstrap.Modal(document.getElementById("addMemberModal"));
            modal.show();
            const list  = document.getElementById("addMemberList");
            const empty = document.getElementById("addMemberEmpty");
            list.innerHTML = `
                <div class="text-center text-muted py-4">
                    <div class="spinner-border spinner-border-sm"></div>
                    <div class="mt-2" style="font-size:.82rem">Loading friends…</div>
                </div>`;
            empty.style.display = "none";
            try {
                const friends = await fetch(
                    `@Url.Action("GetFriendsNotInGroup", "Chat")?chatId=${chatId}`
                ).then(r => r.json());
                list.innerHTML = "";
                if (!friends.length) { empty.style.display = "block"; return; }
                friends.forEach(f => {
                    const img = f.friendProfileImage
                        ?? `https://ui-avatars.com/api/?name=${encodeURIComponent(f.friendUserName)}&background=random`;
                    list.insertAdjacentHTML("beforeend", `
                        <div class="add-friend-row" id="add-row-${f.friendUserId}">
                            <img src="${img}" alt="${esc(f.friendUserName)}" />
                            <span class="flex-grow-1" style="font-size:.88rem">${esc(f.friendUserName)}</span>
                            <button class="btn btn-sm btn-primary px-3"
                                    onclick="addMember('${f.friendUserId}', this)">Add</button>
                        </div>`);
                });
            } catch {
                list.innerHTML = `<div class="text-center text-danger py-3" style="font-size:.85rem">
                    Failed to load friends.</div>`;
            }
        }

        async function addMember(userId, btn) {
            btn.disabled    = true;
            btn.textContent = "Adding…";
            try {
                const res = await postForm('@Url.Action("AddMember", "Chat")', { chatId, userId });
                if (res.success !== false) {
                    btn.textContent = "Added ✓";
                    btn.classList.replace("btn-primary", "btn-success");
                } else {
                    btn.disabled    = false;
                    btn.textContent = "Add";
                    alert(res.message ?? "Failed to add member.");
                }
            } catch {
                btn.disabled    = false;
                btn.textContent = "Add";
                alert("Something went wrong.");
            }
        }

        /* ── Edit Group ─────────────────────────────────────────────── */
        async function saveGroupEdit() {
            const name  = document.getElementById("editGroupName").value.trim();
            const image = document.getElementById("editGroupImage").files[0];
            if (!name) { alert("Group name is required."); return; }
            const btn = document.getElementById("saveGroupBtn");
            btn.disabled    = true;
            btn.textContent = "Saving…";
            try {
                const form = new FormData();
                form.append("chatId", chatId);
                form.append("name",   name);
                if (image) form.append("image", image);
                const res = await postMultipart('@Url.Action("UpdateGroup", "Chat")', form);
                if (res.success !== false) {
                    bootstrap.Modal.getInstance(
                        document.getElementById("editGroupModal")).hide();
                    location.reload();
                } else {
                    alert(res.message ?? "Failed to update group.");
                }
            } catch {
                alert("Something went wrong.");
            } finally {
                btn.disabled    = false;
                btn.textContent = "Save Changes";
            }
        }

        /* ── Append message (from others) ───────────────────────────── */
        function appendMessage(msg) {
            const isOwn = msg.senderId === currentUserId;
            const area  = document.getElementById("messagesArea");
            const time  = new Date(msg.sentAt).toLocaleTimeString([], {
                hour: "2-digit", minute: "2-digit"
            });
            let content = "";
            if (msg.type === "Image")
                content = `<div class="img-bubble"><img src="${esc(msg.fileUrl)}"
                           alt="${esc(msg.fileName)}" onclick="openLightbox(this.src)"/></div>`;
            else if (msg.type === "File")
                content = `<div class="file-bubble"><i class="bi bi-file-earmark-fill"></i>
                           <a href="${esc(msg.fileUrl)}" download="${esc(msg.fileName)}"
                           class="${isOwn ? 'text-white' : ''}">${esc(msg.fileName)}</a></div>`;
            else
                content = esc(msg.content);

            const senderLabel = (chatType === "Group" && !isOwn)
                ? `<div class="sender-name">${esc(msg.senderName)}</div>` : "";

            area.insertAdjacentHTML("beforeend", `
                <div class="msg-row ${isOwn ? "own" : "other"}" data-msg-id="${msg.id}">
                    ${senderLabel}
                    <div class="bubble ${isOwn ? "own" : "other"}">${content}</div>
                    <div class="msg-meta">
                        <span>${time}</span>
                        ${isOwn ? `<span class="read-tick">✓</span>` : ""}
                    </div>
                </div>`);
        }

        /* ── Append local message (optimistic) ──────────────────────── */
        function appendLocalMessage(content) {
            const area = document.getElementById("messagesArea");
            const time = new Date().toLocaleTimeString([], {
                hour: "2-digit", minute: "2-digit"
            });
            area.insertAdjacentHTML("beforeend", `
                <div class="msg-row own pending-msg" data-msg-id="0">
                    <div class="bubble own">${esc(content)}</div>
                    <div class="msg-meta">
                        <span>${time}</span>
                        <span class="read-tick">✓</span>
                    </div>
                </div>`);
        }

        /* ── Helpers ────────────────────────────────────────────────── */
        function scrollToBottom() {
            const a = document.getElementById("messagesArea");
            a.scrollTop = a.scrollHeight;
        }
        function esc(s) {
            if (!s) return "";
            return String(s)
                .replace(/&/g, "&amp;")
                .replace(/</g, "&lt;")
                .replace(/>/g, "&gt;")
                .replace(/"/g, "&quot;");
        }
        function autoResize(el) {
            el.style.height = "";
            el.style.height = Math.min(el.scrollHeight, 120) + "px";
        }

        /* ── Emoji ──────────────────────────────────────────────────── */
        function toggleEmojiPicker() {
            const p = document.getElementById("emojiPicker");
            isPickerOpen = !isPickerOpen;
            p.style.display = isPickerOpen ? "grid" : "none";
        }
        function insertEmoji(e) {
            const inp = document.getElementById("msgInput");
            const pos = inp.selectionStart ?? inp.value.length;
            inp.value = inp.value.slice(0, pos) + e + inp.value.slice(pos);
            inp.focus();
            inp.selectionStart = inp.selectionEnd = pos + e.length;
            document.getElementById("sendBtn").disabled = false;
            if (isPickerOpen) toggleEmojiPicker();
        }
        document.addEventListener("click", e => {
            if (isPickerOpen &&
                !e.target.closest("#emojiPicker") &&
                !e.target.closest(".emoji-btn"))
                toggleEmojiPicker();
        });

        /* ── Lightbox ───────────────────────────────────────────────── */
        function openLightbox(src) {
            document.getElementById("lightboxImg").src = src;
            document.getElementById("lightbox").classList.add("active");
        }
        function closeLightbox() {
            document.getElementById("lightbox").classList.remove("active");
        }
    </script>
}
