@using ChatSystem.Application.DTOs.Friends
@using ChatSystem.Core.Enums
@model FriendsPageDto

@{
    ViewData["Title"] = "Friends";
    Layout = "_AppLayout";
}

@section Styles {
    <style>
        .friends-page {
            max-width: 680px;
            margin: 48px auto;
            padding: 0 1rem;
        }

        .section-heading {
            font-size: 13px;
            font-weight: 600;
            color: #94a3b8;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            margin-bottom: 16px;
            margin-top: 32px;
        }

        .user-card {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 14px 16px;
            background: #fff;
            border: 1px solid #e2e8f0;
            border-radius: 12px;
            margin-bottom: 10px;
            transition: box-shadow 0.15s, border-color 0.15s;
        }

            .user-card:hover {
                border-color: #bfdbfe;
                box-shadow: 0 2px 12px rgba(29,78,216,0.07);
            }

        .user-avatar {
            width: 48px;
            height: 48px;
            border-radius: 50%;
            object-fit: cover;
            flex-shrink: 0;
            border: 2px solid #e2e8f0;
        }

        .user-info {
            flex: 1;
            min-width: 0;
        }

        .user-name {
            font-size: 15px;
            font-weight: 600;
            color: #0f172a;
            margin-bottom: 2px;
        }

        .user-status {
            display: flex;
            align-items: center;
            gap: 5px;
            font-size: 12px;
            font-weight: 500;
            margin-top: 4px;
        }

        .status-dot {
            width: 7px;
            height: 7px;
            border-radius: 50%;
        }

            .status-dot.online {
                background: #22c55e;
            }

            .status-dot.offline {
                background: #cbd5e1;
            }

        .user-status.online {
            color: #16a34a;
        }

        .user-status.offline {
            color: #94a3b8;
        }

        .card-actions {
            display: flex;
            align-items: center;
            gap: 8px;
            flex-shrink: 0;
        }

        .btn-accept {
            padding: 7px 16px;
            border-radius: 8px;
            font-size: 13px;
            font-weight: 500;
            color: #fff;
            border: none;
            background: #1d4ed8;
            cursor: pointer;
            transition: background 0.15s;
        }

            .btn-accept:hover {
                background: #1e40af;
            }

        .btn-reject {
            padding: 7px 16px;
            border-radius: 8px;
            font-size: 13px;
            font-weight: 500;
            color: #dc2626;
            border: 1px solid #fecaca;
            background: #fef2f2;
            cursor: pointer;
            transition: background 0.15s;
        }

            .btn-reject:hover {
                background: #fee2e2;
            }

        .btn-profile {
            padding: 7px 16px;
            border-radius: 8px;
            font-size: 13px;
            font-weight: 500;
            color: #1d4ed8;
            border: 1px solid #bfdbfe;
            background: #eff6ff;
            text-decoration: none;
            transition: background 0.15s;
        }

            .btn-profile:hover {
                background: #dbeafe;
                color: #1d4ed8;
            }

        .btn-message {
            padding: 7px 16px;
            border-radius: 8px;
            font-size: 13px;
            font-weight: 500;
            color: #fff;
            background: #1d4ed8;
            border: none;
            text-decoration: none;
            transition: background 0.15s;
            white-space: nowrap;
        }

            .btn-message:hover {
                background: #1e40af;
                color: #fff;
            }

        .btn-remove {
            padding: 7px 16px;
            border-radius: 8px;
            font-size: 13px;
            font-weight: 500;
            color: #92400e;
            border: 1px solid #fde68a;
            background: #fefce8;
            cursor: pointer;
            transition: background 0.15s;
        }

            .btn-remove:hover {
                background: #fef08a;
            }

        .btn-block {
            padding: 7px 16px;
            border-radius: 8px;
            font-size: 13px;
            font-weight: 500;
            color: #dc2626;
            border: 1px solid #fecaca;
            background: #fef2f2;
            cursor: pointer;
            transition: background 0.15s;
        }

            .btn-block:hover {
                background: #fee2e2;
            }

        .btn-unblock {
            padding: 7px 16px;
            border-radius: 8px;
            font-size: 13px;
            font-weight: 500;
            color: #166534;
            border: 1px solid #bbf7d0;
            background: #f0fdf4;
            cursor: pointer;
            transition: background 0.15s;
        }

            .btn-unblock:hover {
                background: #dcfce7;
            }

        .empty-state {
            text-align: center;
            padding: 48px 0;
            color: #94a3b8;
            font-size: 15px;
        }
    </style>
}

@functions {
    string GetLastSeen(DateTime? lastSeen)
    {
        if (!lastSeen.HasValue) return "Offline";
        var diff = DateTime.UtcNow - lastSeen.Value;
        if (diff.TotalMinutes < 1) return "just now";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours}h ago";
        return $"{(int)diff.TotalDays}d ago";
    }
}

<div class="friends-page">

    @* ===== PENDING REQUESTS ===== *@
    <p class="section-heading">
        Pending Requests
        @if (Model.PendingRequests.Any())
        {
            <span style="background:#1d4ed8;color:#fff;border-radius:99px;
                                 padding:1px 8px;font-size:11px;margin-left:6px;">
                @Model.PendingRequests.Count
            </span>
        }
    </p>

    @if (Model.PendingRequests.Any())
    {
        @foreach (var req in Model.PendingRequests)
        {
            var isOnline = req.SenderStatus == UserStatus.Online;

            <div class="user-card">
                <img src="@(string.IsNullOrEmpty(req.SenderImage)
                                                                   ? "https://ui-avatars.com/api/?name=" + req.SenderName + "&background=1d4ed8&color=fff&size=48"
                                                                   : req.SenderImage)"
                     class="user-avatar" alt="@req.SenderName" />

                <div class="user-info">
                    <div class="user-name">@req.SenderName</div>
                    <div class="user-status @(isOnline ? "online" : "offline")">
                        <div class="status-dot @(isOnline ? "online" : "offline")"></div>
                        @(isOnline ? "Online" : "Last seen " + GetLastSeen(req.CreatedAt))
                    </div>
                </div>

                <div class="card-actions">
                    <form method="post" asp-controller="FriendRequest" asp-action="Accept">
                        <input type="hidden" name="requestId" value="@req.RequestId" />
                        <button type="submit" class="btn-accept">✓ Accept</button>
                    </form>
                    <form method="post" asp-controller="FriendRequest" asp-action="Reject">
                        <input type="hidden" name="requestId" value="@req.RequestId" />
                        <button type="submit" class="btn-reject">✕ Reject</button>
                    </form>
                </div>
            </div>
        }
    }
    else
    {
        <div class="empty-state">No pending requests</div>
    }

    @* ===== MY FRIENDS ===== *@
    <p class="section-heading">
        My Friends (@Model.MyFriends.Count)
    </p>

    @if (Model.MyFriends.Any())
    {
        @foreach (var friend in Model.MyFriends)
        {
            var iBlockedHim = friend.MyStatus == FriendsStatus.Blocked;
            var heBlockedMe = friend.TheirStatus == FriendsStatus.Blocked;
            var isActive = !iBlockedHim && !heBlockedMe;
            var isOnline = friend.Status == UserStatus.Online;

            <div class="user-card">
                <img src="@(string.IsNullOrEmpty(friend.ProfileImage)
                                                                   ? "https://ui-avatars.com/api/?name=" + friend.UserName + "&background=1d4ed8&color=fff&size=48"
                                                                   : friend.ProfileImage)"
                     class="user-avatar" alt="@friend.UserName" />

                <div class="user-info">
                    <div class="user-name">@friend.UserName</div>
                    <div class="user-status @(isOnline ? "online" : "offline")">
                        <div class="status-dot @(isOnline ? "online" : "offline")"></div>
                        @(isOnline ? "Online" : "Last seen " + GetLastSeen(friend.LastSeen))
                    </div>
                </div>

                <div class="card-actions">

                    @if (!iBlockedHim)
                    {
                        <a asp-controller="Search"
                           asp-action="ShowProfile"
                       asp-route-id="@friend.UserId"
                       class="btn-profile">
                        View Profile
                    </a>
                    <a asp-controller="Chat"
                       asp-action="Index"
                       asp-route-id="@friend.UserId"
                       class="btn-message">
                        💬 Message
                    </a>
                    }


                    <form method="post" asp-controller="Friends" asp-action="Remove">
                        <input type="hidden" name="friendId" value="@friend.UserId" />
                        <button type="submit" class="btn-remove">Remove</button>
                    </form>

                    @if (!iBlockedHim)
                    {
                        <form method="post" asp-controller="Friends" asp-action="Block">
                            <input type="hidden" name="blockedId" value="@friend.UserId" />
                            <button type="submit" class="btn-block">Block</button>
                        </form>
                    }
                    else
                    {
                        <form method="post" asp-controller="Friends" asp-action="Unblock">
                            <input type="hidden" name="blockedId" value="@friend.UserId" />
                            <button type="submit" class="btn-unblock">Unblock</button>
                        </form>
                    }

                </div>
            </div>
        }
    }
    else
    {
        <div class="empty-state">No friends yet</div>
    }

</div>